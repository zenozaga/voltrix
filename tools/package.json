{
  "name": "@voltrix/tools",
  "version": "0.1.0",
  "description": "Development tools and utilities for Voltrix monorepo maintenance",
  "type": "module",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean.js",
    "clean:dist": "node scripts/clean.js --dist",
    "clean:node-modules": "node scripts/clean.js --node-modules",
    "clean:all": "node scripts/clean.js --all",
    "clean:cache": "node scripts/clean.js --cache",
    "reset": "node scripts/reset.js",
    "analyze": "node scripts/analyze.js",
    "deps:check": "node scripts/check-dependencies.js",
    "deps:update": "node scripts/update-dependencies.js",
    "size:report": "node scripts/size-report.js"
  },
  "dependencies": {
    "@voltrix/tools": "file:",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.3",
    "filesize": "^10.1.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0"
  },
  "keywords": [
    "tools",
    "utilities",
    "monorepo",
    "cleanup",
    "maintenance",
    "voltrix"
  ],
  "author": "@zenozaga",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zenozaga/voltrix.git",
    "directory": "tools"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
