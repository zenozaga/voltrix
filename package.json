{
  "name": "@voltrix/monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Ultra-fast REST API framework built on uWebSockets.js with Express-like API",
  "packageManager": "pnpm@8.15.0",
  "author": "@zenozaga",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zenozaga/voltrix.git"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:watch": "pnpm -r --parallel build:watch",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r --parallel test:watch",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "type-check": "pnpm -r type-check",
    "dev": "pnpm -r --parallel dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "bench": "pnpm --filter @voltrix/benchs bench:comprehensive",
    "bench:all": "pnpm --filter @voltrix/benchs bench:all",
    "bench:simple": "pnpm --filter @voltrix/benchs bench:simple",
    "bench:vs-express": "pnpm --filter @voltrix/benchs bench:vs-express",
    "bench:uws": "pnpm --filter @voltrix/benchs bench:uws",
    "clean": "cd tools && pnpm clean",
    "clean:all": "cd tools && pnpm clean:all",
    "clean:dist": "cd tools && pnpm clean:dist",
    "clean:node-modules": "cd tools && pnpm clean:node-modules",
    "reset": "cd tools && pnpm reset",
    "analyze": "cd tools && pnpm analyze",
    "deps:check": "cd tools && pnpm deps:check",
    "size:report": "cd tools && pnpm size:report",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "8.46.0",
    "@typescript-eslint/parser": "8.46.0",
    "eslint": "9.37.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.1.0",
    "prettier": "^3.1.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.0",
    "tslib": "^2.8.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "web-framework",
    "http-server",
    "uwebsockets",
    "express",
    "performance",
    "typescript",
    "monorepo"
  ]
}