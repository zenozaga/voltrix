{
  "name": "@voltrix/swagger",
  "version": "0.1.0",
  "description": "OpenAPI 3.0 generator for Voltrix framework",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "voltrix",
    "swagger",
    "openapi"
  ],
  "author": "Voltrix Team",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@voltrix/core": "workspace:*",
    "@voltrix/express": "workspace:*"
  }
}
