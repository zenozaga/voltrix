{
  "name": "@voltrix/decorator",
  "version": "0.1.0",
  "description": "Comprehensive TypeScript decorator library for Voltrix Express framework",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": [
    "voltrix",
    "decorators",
    "typescript",
    "express",
    "routing",
    "validation",
    "dependency-injection",
    "middleware",
    "performance"
  ],
  "author": "Voltrix Team",
  "license": "MIT",
  "dependencies": {
    "@voltrix/express": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "8.46.0",
    "@typescript-eslint/parser": "8.46.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.37.0",
    "tsup": "^8.0.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zenozaga/voltrix.git",
    "directory": "packages/decorator"
  },
  "bugs": {
    "url": "https://github.com/zenozaga/voltrix/issues"
  },
  "homepage": "https://github.com/zenozaga/voltrix/tree/main/packages/decorator#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}