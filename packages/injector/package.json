{
  "name": "@voltrix/injector",
  "version": "0.1.0",
  "description": "Dependency injection container with decorator and reflect-metadata support for Voltrix framework",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc --watch",
    "test": "vitest run",
    "bench": "vitest bench",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": [
    "voltrix",
    "injector",
    "dependency-injection",
    "typescript",
    "reflect-metadata",
    "decorators",
    "ioc",
    "container"
  ],
  "author": "Voltrix Team",
  "license": "MIT",
  "dependencies": {
    "tslib": "^2.8.1",
    "reflect-metadata": "^0.2.2",
    "@voltrix/core": "workspace:*"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zenozaga/voltrix.git",
    "directory": "packages/injector"
  },
  "bugs": {
    "url": "https://github.com/zenozaga/voltrix/issues"
  },
  "homepage": "https://github.com/zenozaga/voltrix/tree/main/packages/injector#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "ts-node": "^10.9.2"
  }
}