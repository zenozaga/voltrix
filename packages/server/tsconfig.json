{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true,
    "composite": false,
    "incremental": false,
    "noEmit": false,
    "importHelpers": true
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "tests", "**/*.test.ts", "**/*.spec.ts"]
}
