{
    "name": "@voltrix/mock",
    "version": "0.1.0",
    "description": "Mock data generation and API mocking middleware for Voltrix",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src --ext .ts",
        "clean": "rimraf dist"
    },
    "keywords": [
        "voltrix",
        "mock",
        "api",
        "testing",
        "fake-data",
        "middleware",
        "development"
    ],
    "author": "Voltrix Team",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/zenozaga/voltrix",
        "directory": "packages/mock"
    },
    "dependencies": {
        "@voltrix/express": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "typescript": "5.9.3",
        "tsup": "^8.0.0",
        "vitest": "3.2.4"
    },
    "peerDependencies": {
        "@voltrix/express": "^0.1.0"
    }
}