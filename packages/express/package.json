{
  "name": "@voltrix/express",
  "version": "0.1.0",
  "description": "Ultra-fast Express-compatible framework built on uWebSockets.js",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:watch": "tsc --watch",
    "test": "vitest",
    "benchmark": "vitest bench",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.60.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@voltrix/core": "workspace:*",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": [
    "web",
    "framework",
    "express",
    "uwebsockets",
    "fast",
    "performance",
    "http",
    "server",
    "typescript"
  ],
  "author": "@zenozaga",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zenozaga/voltrix.git",
    "directory": "packages/express"
  },
  "bugs": {
    "url": "https://github.com/zenozaga/voltrix/issues"
  },
  "homepage": "https://github.com/zenozaga/voltrix/tree/main/packages/express",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}