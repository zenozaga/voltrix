{
  "name": "@voltrix/mcp",
  "version": "0.1.0",
  "description": "Ultra-lightweight Model Context Protocol implementation with tree-shaking support",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./builder": {
      "import": "./dist/builder/index.js",
      "require": "./dist/builder/index.cjs",
      "types": "./dist/builder/index.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "require": "./dist/plugins/index.cjs",
      "types": "./dist/plugins/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "voltrix",
    "typescript",
    "tree-shaking",
    "lightweight"
  ],
  "author": "Voltrix Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zenozaga/voltrix.git",
    "directory": "packages/mcp"
  },
  "sideEffects": false,
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}