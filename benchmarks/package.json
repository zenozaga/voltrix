{
  "name": "@voltrix/benchmarks",
  "version": "0.1.0",
  "description": "Benchmark runners for @voltrix/server, Voltrix, uWebSockets.js, and Node baselines",
  "type": "module",
  "private": true,
  "scripts": {
    "bench": "node bench/run.mjs",
    "bench:autocannon": "node bench/run.mjs",
    "bench:vitest": "vitest bench --run --config vitest.config.ts",
    "bench:server": "vitest bench bench/voltrix-server.bench.ts --run --config vitest.config.ts"
  },
  "dependencies": {
    "autocannon": "^8.0.0",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.44.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "benchmark",
    "performance",
    "voltrix",
    "express",
    "fastify",
    "koa",
    "hapi",
    "uwebsockets",
    "testing"
  ],
  "author": "@zenozaga",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zenozaga/voltrix.git",
    "directory": "benchmarks"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
